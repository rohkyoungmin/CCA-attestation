# Reuse qemu_cortex_a53 SoC (ARM Cortex-A53, same arch)
CONFIG_SOC_QEMU_CORTEX_A53=y
CONFIG_BOARD_LKVM_REALM=y

CONFIG_SMP=n
CONFIG_SYS_CLOCK_TICKS_PER_SEC=100

# Console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_SERIAL=y
CONFIG_UART_NS16550=y
CONFIG_UART_INTERRUPT_DRIVEN=n

# No GIC, no timer - polling only for Realm boot
CONFIG_ARM_ARCH_TIMER=n
CONFIG_SYS_CLOCK_EXISTS=n

# Disable unused drivers
CONFIG_GPIO=n
CONFIG_I2C=n
CONFIG_SPI=n
