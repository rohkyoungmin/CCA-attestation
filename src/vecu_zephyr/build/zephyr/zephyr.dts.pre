# 6 "/home/csos/NDSS/SCRUTINIZER/src/vecu_zephyr/boards/arm64/lkvm_realm/lkvm_realm.dts" 2

/ {
 #address-cells = <2>;
 #size-cells = <2>;
 compatible = "lkvm,realm";
 model = "lkvm Realm VM (ARM64)";

 chosen {
  zephyr,sram = &sram0;
  zephyr,console = &uart0;
  zephyr,shell-uart = &uart0;
 };

 cpus {
  #address-cells = <1>;
  #size-cells = <0>;
  cpu@0 {
   device_type = "cpu";
   compatible = "arm,cortex-a53";
   reg = <0>;
   enable-method = "psci";
  };
 };

 psci {
  compatible = "arm,psci-0.2";
  method = "hvc";
 };

 timer {
  compatible = "arm,armv8-timer";
  interrupt-parent = <&gic>;
  interrupts = <0x1 13 (1UL << (1)) 0xa0>,
        <0x1 14 (1UL << (1)) 0xa0>,
        <0x1 11 (1UL << (1)) 0xa0>,
        <0x1 10 (1UL << (1)) 0xa0>;
 };

 soc {
  #address-cells = <2>;
  #size-cells = <2>;
  ranges;


  gic: interrupt-controller@3fff0000 {
   compatible = "arm,gic-v3", "arm,gic";
   reg = <0x00 0x3fff0000 0x00 0x10000>,
         <0x00 0x3ffd0000 0x00 0x20000>;
   interrupt-controller;
   #interrupt-cells = <4>;
   #address-cells = <2>;
   #size-cells = <2>;
   status = "okay";
  };


  uart0: uart@1000000 {
   compatible = "ns16550";
   reg = <0x00 0x1000000 0x00 0x8>;
   reg-shift = <0>;
   clock-frequency = <1843200>;
   current-speed = <115200>;
   interrupts = <0x0 0 (1UL << (1)) 0>;
   interrupt-parent = <&gic>;
   status = "okay";
  };
 };


 sram0: memory@80000000 {
  compatible = "mmio-sram";
  reg = <0x00 0x80000000 0x00 0x4000000>;
 };
};
