+static bool realm_write_token_meta(const char *path,
+				   const struct realm_comm_ctrl *ctrl,
+				   u64 ctrl_gpa, u64 token_gpa,
+				   const char *token_path)
+{
+	FILE *fp = fopen(path, "w");
+	size_t i;
+
+	if (fp == NULL) {
+		pr_warning("realm token failed to open %s: %s",
+			   path, strerror(errno));
+		return false;
+	}
+
+	fprintf(fp, "magic=0x%08x\n", ctrl->magic);
+	fprintf(fp, "token_ready=%u\n", ctrl->token_ready);
+	fprintf(fp, "token_size=%u\n", ctrl->token_size);
+	fprintf(fp, "gen_count=%u\n", ctrl->gen_count);
+	fprintf(fp, "gen_time_ns=%llu\n",
+		(unsigned long long)ctrl->gen_time_ns);
+	fprintf(fp, "ctrl_gpa=0x%llx\n", (unsigned long long)ctrl_gpa);
+	fprintf(fp, "token_gpa=0x%llx\n", (unsigned long long)token_gpa);
+	fprintf(fp, "token_file=%s\n", token_path);
+	fprintf(fp, "challenge=");
+	for (i = 0; i < sizeof(ctrl->challenge); i++)
+		fprintf(fp, "%02x", ctrl->challenge[i]);
+	fprintf(fp, "\n");
+
+	if (fclose(fp) != 0) {
+		pr_warning("realm token failed to close %s: %s",
+			   path, strerror(errno));
+		return false;
+	}
+
+	return true;
+}
