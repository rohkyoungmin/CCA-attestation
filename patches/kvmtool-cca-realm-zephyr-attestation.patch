+static bool realm_fd_wait(int fd, short events, int timeout_ms)
+{
+	struct pollfd pfd = {
+		.fd = fd,
+		.events = events,
+	};
+	int ret;
+
+	do {
+		ret = poll(&pfd, 1, timeout_ms);
+	} while (ret < 0 && errno == EINTR);
+
+	return ret > 0 && (pfd.revents & events);
+}
