+static void *vcpu_trace_thread(void *arg)
+{
+	struct kvm *kvm = arg;
+	struct kvm_cpu *vcpu;
+	u64 last_pc = ~0ULL;
+	u64 last_pstate = ~0ULL;
+	const char *guest_kind;
+
+	if (!kvm->cpus || !kvm->cpus[0])
+		return NULL;
+
+	vcpu = kvm->cpus[0];
+	guest_kind = kvm->cfg.arch.is_realm ? "realm" : "normal";
+
+	while (vcpu->is_running) {
+		u64 pc = 0;
+		u64 pstate = 0;
+
+		if (!read_vcpu_u64_reg(vcpu, ARM64_CORE_REG(regs.pc), &pc) ||
+		    !read_vcpu_u64_reg(vcpu, ARM64_CORE_REG(regs.pstate), &pstate)) {
+			break;
+		}
+
+		if (pc != last_pc || pstate != last_pstate) {
+			pr_debug("%s guest %s vcpu%lu live pc=0x%llx pstate=0x%llx",
+				 guest_kind, kvm->cfg.guest_name, vcpu->cpu_id, pc,
+				 pstate);
+			last_pc = pc;
+			last_pstate = pstate;
+		}
+
+		usleep(100000);
+	}
+
+	return NULL;
+}
