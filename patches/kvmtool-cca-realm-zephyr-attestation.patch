+static void log_realm_entry_state(struct kvm_cpu *vcpu)
+{
+	u64 pc = read_core_reg(vcpu, ARM64_CORE_REG(regs.pc), "pc");
+	u64 x0 = read_core_reg(vcpu, ARM64_CORE_REG(regs.regs[0]), "x0");
+	u64 pstate = read_core_reg(vcpu, ARM64_CORE_REG(regs.pstate), "pstate");
+
+	pr_debug("vcpu%ld entry pc=0x%llx x0=0x%llx pstate=0x%llx",
+		 vcpu->cpu_id, pc, x0, pstate);
