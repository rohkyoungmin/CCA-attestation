+static bool realm_write_full_timeout(int fd, const void *buf, size_t len,
+				     int timeout_ms)
+{
+	const u8 *p = buf;
+
+	while (len > 0) {
+		ssize_t n;
+
+		if (!realm_fd_wait(fd, POLLOUT, timeout_ms))
+			return false;
+
+		n = write(fd, p, len);
+		if (n < 0) {
+			if (errno == EINTR)
+				continue;
+			return false;
+		}
+		if (n == 0)
+			return false;
+		p += n;
+		len -= n;
+	}
+
+	return true;
+}
+
+static bool realm_read_full_timeout(int fd, void *buf, size_t len,
+				    int timeout_ms)
+{
+	u8 *p = buf;
+
+	while (len > 0) {
+		ssize_t n;
+
+		if (!realm_fd_wait(fd, POLLIN, timeout_ms))
+			return false;
+
+		n = read(fd, p, len);
+		if (n < 0) {
+			if (errno == EINTR)
+				continue;
+			return false;
+		}
+		if (n == 0)
+			return false;
+		p += n;
+		len -= n;
+	}
+
+	return true;
+}
+
+static void realm_agl_verifier_init(struct realm_agl_verifier *agl)
+{
+	struct sockaddr_in addr;
+	int flags;
+	int opt = 1;
+
+	agl->enabled = realm_env_bool("LKVM_REALM_AGL_VERIFY");
+	agl->listen_fd = -1;
+	agl->client_fd = -1;
+	agl->port = (int)realm_env_u64("LKVM_REALM_AGL_VERIFY_PORT",
+				       REALM_AGL_DEFAULT_PORT);
+	agl->timeout_ms = (int)realm_env_u64("LKVM_REALM_AGL_VERIFY_TIMEOUT_MS",
+					     REALM_AGL_DEFAULT_TIMEOUT_MS);
+
+	if (!agl->enabled)
+		return;
+
+	agl->listen_fd = socket(AF_INET, SOCK_STREAM, 0);
+	if (agl->listen_fd < 0) {
+		pr_warning("realm AGL verifier socket failed: %s",
+			   strerror(errno));
+		agl->enabled = false;
+		return;
+	}
+
+	setsockopt(agl->listen_fd, SOL_SOCKET, SO_REUSEADDR,
+		   &opt, sizeof(opt));
+
+	memset(&addr, 0, sizeof(addr));
+	addr.sin_family = AF_INET;
+	addr.sin_addr.s_addr = htonl(INADDR_ANY);
+	addr.sin_port = htons((uint16_t)agl->port);
+
+	if (bind(agl->listen_fd, (struct sockaddr *)&addr, sizeof(addr)) < 0 ||
+	    listen(agl->listen_fd, 1) < 0) {
+		pr_warning("realm AGL verifier listen on port %d failed: %s",
+			   agl->port, strerror(errno));
+		close(agl->listen_fd);
+		agl->listen_fd = -1;
+		agl->enabled = false;
+		return;
+	}
+
+	flags = fcntl(agl->listen_fd, F_GETFL, 0);
+	if (flags >= 0)
+		fcntl(agl->listen_fd, F_SETFL, flags | O_NONBLOCK);
+
+	pr_info("realm AGL verifier waiting on port %d", agl->port);
+}
+
+static u32 realm_agl_verify_token(struct realm_agl_verifier *agl,
+				  u32 gen, u32 token_size, u64 gen_time_ns,
+				  const void *token,
+				  u64 *agl_verify_ns,
+				  u64 *agl_hash_ns)
+{
+	struct realm_agl_verify_req req = {
+		.magic = REALM_AGL_PROTO_MAGIC,
+		.version = REALM_AGL_PROTO_VERSION,
+		.gen = gen,
+		.token_size = token_size,
+		.realm_gen_time_ns = gen_time_ns,
+	};
+	struct realm_agl_verify_resp resp;
+
+	if (agl_verify_ns)
+		*agl_verify_ns = 0;
+	if (agl_hash_ns)
+		*agl_hash_ns = 0;
+
+	if (!agl->enabled)
+		return REALM_COMM_HOST_STATUS_OK;
+
+	realm_agl_accept_client(agl);
+	if (agl->client_fd < 0)
+		return REALM_COMM_HOST_STATUS_AGL_NO_VERIFIER;
+
+	if (!realm_write_full_timeout(agl->client_fd, &req, sizeof(req),
+				      agl->timeout_ms) ||
+	    !realm_write_full_timeout(agl->client_fd, token, token_size,
+				      agl->timeout_ms) ||
+	    !realm_read_full_timeout(agl->client_fd, &resp, sizeof(resp),
+				     agl->timeout_ms)) {
+		pr_warning("realm AGL verifier disconnected or timed out");
+		realm_agl_close_client(agl);
+		return REALM_COMM_HOST_STATUS_AGL_NO_VERIFIER;
+	}
+
+	if (resp.magic != REALM_AGL_PROTO_MAGIC ||
+	    resp.version != REALM_AGL_PROTO_VERSION ||
+	    resp.gen != gen ||
+	    resp.status != 0) {
+		pr_warning("realm AGL verifier rejected token gen=%u status=%u",
+			   gen, resp.status);
+		return REALM_COMM_HOST_STATUS_AGL_VERIFY_FAIL;
+	}
+
+	if (agl_verify_ns)
+		*agl_verify_ns = resp.total_ns;
+	if (agl_hash_ns)
+		*agl_hash_ns = resp.hash_ns;
+
+	pr_info("realm AGL verifier ack gen=%u token_size=%u parse_ns=%llu hash_ns=%llu total_ns=%llu",
+		gen, token_size,
+		(unsigned long long)resp.parse_ns,
+		(unsigned long long)resp.hash_ns,
+		(unsigned long long)resp.total_ns);
+
+	return REALM_COMM_HOST_STATUS_OK;
+}
+
+static void *realm_token_thread(void *arg)
+{
+	struct kvm *kvm = arg;
+	struct kvm_cpu *vcpu;
+	struct realm_comm_ctrl *ctrl;
+	u8 *token;
+	u64 ctrl_gpa;
+	u64 token_gpa;
+	const char *token_path;
+	const char *meta_path;
+	u32 last_gen_count = 0;
+	u32 last_bad_gen_count = 0;
+	u32 last_host_gen = 0;
+	struct realm_agl_verifier agl;
+
+	if (!kvm->cpus || !kvm->cpus[0])
+		return NULL;
+
+	vcpu = kvm->cpus[0];
+	ctrl_gpa = realm_env_u64("LKVM_REALM_TOKEN_CTRL_GPA",
+				 REALM_TOKEN_CTRL_DEFAULT_GPA);
+	token_gpa = realm_env_u64("LKVM_REALM_TOKEN_GPA",
+				  REALM_TOKEN_DEFAULT_GPA);
+	token_path = realm_env_path("LKVM_REALM_TOKEN_OUT",
+				    "/root/realm-token.bin");
+	meta_path = realm_env_path("LKVM_REALM_TOKEN_META",
+				   "/root/realm-token.meta");
+
+	ctrl = guest_flat_to_host(kvm, ctrl_gpa);
+	token = guest_flat_to_host(kvm, token_gpa);
+	if (ctrl == NULL || token == NULL) {
+		pr_warning("realm token watch failed to resolve ctrl=0x%llx token=0x%llx",
+			   (unsigned long long)ctrl_gpa,
+			   (unsigned long long)token_gpa);
+		return NULL;
+	}
+
+	pr_debug("realm token watch ctrl_gpa=0x%llx token_gpa=0x%llx token_out=%s meta=%s",
+		 (unsigned long long)ctrl_gpa,
+		 (unsigned long long)token_gpa,
+		 token_path, meta_path);
+	realm_agl_verifier_init(&agl);
+
+	while (vcpu->is_running) {
+		struct realm_comm_ctrl cur;
+		u8 token_copy[REALM_TOKEN_MAX_SIZE];
+
+		memcpy(&cur, ctrl, sizeof(cur));
+		realm_agl_accept_client(&agl);
+
+		if (cur.magic == REALM_COMM_MAGIC &&
+		    cur.host_req == REALM_COMM_HOST_REQ_NORMAL &&
+		    cur.host_gen != 0 && cur.host_gen != last_host_gen) {
+			char msg[REALM_COMM_HOST_MSG_SIZE + 1];
+			u32 host_status = REALM_COMM_HOST_STATUS_OK;
+			u64 agl_verify_ns = 0;
+			u64 agl_hash_ns = 0;
+
+			memcpy(msg, cur.host_msg, REALM_COMM_HOST_MSG_SIZE);
+			msg[REALM_COMM_HOST_MSG_SIZE] = '\0';
+			for (size_t i = 0; i < REALM_COMM_HOST_MSG_SIZE && msg[i]; i++) {
+				if (!isprint((unsigned char)msg[i]))
+					msg[i] = '.';
+			}
+
+			if (!strncmp(msg, "attest", 6)) {
+				if (cur.token_ready != 1 ||
+				    cur.token_size == 0 ||
+				    cur.token_size > REALM_TOKEN_MAX_SIZE ||
+				    cur.gen_count == 0) {
+					host_status = REALM_COMM_HOST_STATUS_NO_TOKEN;
+				} else {
+					/*
+					 * The paper-facing measurement path is a
+					 * Normal World consume/ack, not filesystem
+					 * throughput. Copy the token out of guest
+					 * memory here and mark this generation as
+					 * consumed so the generic dump path below
+					 * does not add per-iteration file I/O.
+					 */
+					memcpy(token_copy, token, cur.token_size);
+					last_gen_count = cur.gen_count;
+					host_status = realm_agl_verify_token(&agl,
+									     cur.host_gen,
+									     cur.token_size,
+									     cur.gen_time_ns,
+									     token_copy,
+									     &agl_verify_ns,
+									     &agl_hash_ns);
+				}
+				pr_info("realm normal-world attest request gen=%u req=%u token_gen=%u token_size=%u token_gen_time_ns=%llu status=%u",
+					cur.host_gen, cur.host_req,
+					cur.gen_count, cur.token_size,
+					(unsigned long long)cur.gen_time_ns,
+					host_status);
+			} else {
+				pr_info("realm normal-world request gen=%u req=%u arg0=0x%llx arg1=0x%llx msg=\"%s\"",
+					cur.host_gen, cur.host_req,
+					(unsigned long long)cur.host_arg0,
+					(unsigned long long)cur.host_arg1,
+					msg);
+			}
+
+			ctrl->host_status = host_status;
+			ctrl->host_arg0 = agl_verify_ns;
+			ctrl->host_arg1 = agl_hash_ns;
+			__sync_synchronize();
+			ctrl->host_ack = cur.host_gen;
+			last_host_gen = cur.host_gen;
+		}
+
+		if (cur.magic != REALM_COMM_MAGIC || cur.token_ready != 1) {
+			usleep(REALM_TOKEN_WATCH_POLL_US);
+			continue;
+		}
+
+		if (cur.gen_count == last_gen_count) {
+			usleep(REALM_TOKEN_WATCH_POLL_US);
+			continue;
+		}
+
+		if (cur.token_size == 0 || cur.token_size > REALM_TOKEN_MAX_SIZE) {
+			if (cur.gen_count != last_bad_gen_count) {
+				pr_warning("realm token invalid size gen=%u size=%u",
+					   cur.gen_count, cur.token_size);
+				last_bad_gen_count = cur.gen_count;
+			}
+			usleep(REALM_TOKEN_WATCH_POLL_US);
+			continue;
+		}
+
+		memcpy(token_copy, token, cur.token_size);
+		if (!realm_write_binary_file(token_path, token_copy, cur.token_size)) {
+			usleep(REALM_TOKEN_WATCH_POLL_US);
+			continue;
+		}
+		realm_write_token_meta(meta_path, &cur, ctrl_gpa, token_gpa,
+				       token_path);
+
+		pr_debug("realm token published gen=%u size=%u gen_time_ns=%llu token=%s meta=%s",
+			 cur.gen_count, cur.token_size,
+			 (unsigned long long)cur.gen_time_ns,
+			 token_path, meta_path);
+		last_gen_count = cur.gen_count;
+
+		usleep(REALM_TOKEN_WATCH_POLL_US);
+	}
+
+	return NULL;
+}
+
+static void *realm_status_thread(void *arg)
+{
+	struct kvm *kvm = arg;
+	struct kvm_cpu *vcpu;
+	struct realm_status_page *page;
+	struct realm_status_page last = { 0 };
+	u64 gpa;
+
+	if (!kvm->cpus || !kvm->cpus[0]) {
+		return NULL;
+	}
+
+	vcpu = kvm->cpus[0];
+	gpa = realm_status_watch_gpa();
+	page = guest_flat_to_host(kvm, gpa);
+	if (page == NULL) {
+		pr_warning("Realm status watch failed to resolve GPA 0x%llx",
+			   (unsigned long long)gpa);
+		return NULL;
+	}
+
+	memset(page, 0, PAGE_SIZE);
+	pr_debug("realm status watch gpa=0x%llx host=%p",
+		 (unsigned long long)gpa, page);
+
+	while (vcpu->is_running) {
+		struct realm_status_page cur;
+
+		memcpy(&cur, page, sizeof(cur));
+		if (memcmp(&cur, &last, sizeof(cur)) != 0) {
+			if (cur.magic == REALM_STATUS_MAGIC) {
+				pr_debug("realm status phase=%u(%s) heartbeat=%u value0=%llu value1=%llu text=\"%s\"",
+					 cur.phase, realm_status_phase_name(cur.phase),
+					 cur.heartbeat,
+					 (unsigned long long)cur.value0,
+					 (unsigned long long)cur.value1,
+					 cur.text);
+			} else {
+				pr_debug("realm status raw update magic=0x%x phase=%u heartbeat=%u",
+					 cur.magic, cur.phase, cur.heartbeat);
+			}
+			last = cur;
+		}
+
+		usleep(100000);
+	}
+
+	return NULL;
+}
 
