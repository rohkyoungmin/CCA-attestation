+static bool realm_write_binary_file(const char *path, const void *buf, size_t len)
+{
+	FILE *fp = fopen(path, "wb");
+
+	if (fp == NULL) {
+		pr_warning("realm token failed to open %s: %s",
+			   path, strerror(errno));
+		return false;
+	}
+
+	if (fwrite(buf, 1, len, fp) != len) {
+		pr_warning("realm token failed to write %s: %s",
+			   path, strerror(errno));
+		fclose(fp);
+		return false;
+	}
+
+	if (fclose(fp) != 0) {
+		pr_warning("realm token failed to close %s: %s",
+			   path, strerror(errno));
+		return false;
+	}
+
+	return true;
+}
