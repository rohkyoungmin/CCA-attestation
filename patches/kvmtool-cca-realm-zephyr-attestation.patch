+static u64 realm_entry_offset(void)
+{
+	static bool parsed;
+	static u64 offset;
+	const char *env;
+	char *endptr;
+
+	if (parsed)
+		return offset;
+
+	parsed = true;
+	env = getenv("LKVM_REALM_ENTRY_OFFSET");
+	if (!env || !*env)
+		return 0;
+
+	offset = strtoull(env, &endptr, 0);
+	if (endptr == env || *endptr != '\0') {
+		pr_warning("Ignoring invalid LKVM_REALM_ENTRY_OFFSET='%s'", env);
+		offset = 0;
+		return 0;
+	}
+
+	pr_info("Using Realm entry offset 0x%llx", offset);
+	return offset;
+}
