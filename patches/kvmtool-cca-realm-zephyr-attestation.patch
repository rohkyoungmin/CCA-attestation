+static void realm_agl_close_client(struct realm_agl_verifier *agl)
+{
+	if (agl->client_fd >= 0) {
+		close(agl->client_fd);
+		agl->client_fd = -1;
+	}
+}
+
+static void realm_agl_accept_client(struct realm_agl_verifier *agl)
+{
+	struct sockaddr_in addr;
+	socklen_t addrlen = sizeof(addr);
+	int fd;
+
+	if (!agl->enabled || agl->client_fd >= 0)
+		return;
+
+	fd = accept(agl->listen_fd, (struct sockaddr *)&addr, &addrlen);
+	if (fd < 0) {
+		if (errno != EAGAIN && errno != EWOULDBLOCK) {
+			pr_warning("realm AGL verifier accept failed: %s",
+				   strerror(errno));
+		}
+		return;
+	}
+
+	agl->client_fd = fd;
+	pr_info("realm AGL verifier connected on port %d", agl->port);
+}
